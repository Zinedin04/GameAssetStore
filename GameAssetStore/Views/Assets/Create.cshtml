@model GameAssetStore.Models.Asset

@{
    ViewData["Title"] = "Upload New Asset";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary bg-gradient text-white p-4 rounded-top-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-cloud-arrow-up fs-2 me-3"></i>
                        <div>
                            <h3 class="mb-0">Publish New Asset</h3>
                            <p class="mb-0 opacity-75">Upload your 3D models directly to our GitHub-powered store.</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-pencil"></i></span>
                                    <input asp-for="Name" class="form-control" placeholder="e.g. Cyberpunk Building Pack" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-bold"></label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the model, polygon count, textures..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-bold"></label>
                                <div class="input-group border rounded-2">
                                    <span class="input-group-text bg-light border-0">$</span>
                                    <input asp-for="Price" class="form-control border-0" type="number" step="0.01" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold text-secondary text-uppercase small px-1">Asset File (.obj, .fbx)</label>
                                <div class="upload-zone border border-2 border-dashed rounded-4 p-5 text-center shadow-sm"
                                     style="background-color: #f1f3f5; border-color: #ced4da !important;">

                                    <div class="mb-3">
                                        <div class="icon-circle bg-white shadow-sm d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
                                            <i class="bi bi-cloud-arrow-up display-5 text-primary"></i>
                                        </div>
                                    </div>

                                    <h6 class="fw-bold text-dark">Click to upload or drag and drop</h6>
                                    <p class="text-muted small mb-4">OBJ, FBX or other 3D formats are supported</p>

                                    <input type="file" name="file" class="form-control bg-white border-0 shadow-sm py-2" required />

                                    <div class="mt-3 d-flex justify-content-center">
                                        <span class="badge bg-dark-subtle text-muted fw-normal px-3 py-2 rounded-pill">
                                            <i class="bi bi-shield-lock me-1"></i> Secure GitHub Storage
                                        </span>
                                    </div>
                                </div>
                                <div class="mb-4 p-4 border rounded-4 shadow-sm bg-light">
                                    <label class="form-label fw-bold text-dark">
                                        <i class="bi bi-image me-2 text-success"></i>Asset Preview Image (Thumbnail)
                                    </label>

                                    <input type="file" name="imageFile" accept="image/*" class="form-control border-0 shadow-sm" />

                                    <div class="mt-2">
                                        <small class="text-muted italic">Preporučeno: 800x600px (JPG, PNG)</small>
                                    </div>
                                </div>
                            </div>


                            <style>
                                
                            </style>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 py-2 rounded-3 shadow">
                                <i class="bi bi-plus-circle me-2"></i>Create & Upload
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3 mb-5">
                <a asp-action="Index" class="text-muted small text-decoration-none">
                    <i class="bi bi-chevron-left me-1"></i>Back to Assets List
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
    }

    .upload-zone {
        transition: all 0.2s ease-in-out;
    }

        .upload-zone:hover {
            background-color: #f0f4f8 !important;
            border-color: #0d6efd !important;
        }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
