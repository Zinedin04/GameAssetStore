@model GameAssetStore.Models.Asset

@{
    ViewData["Title"] = "Edit Asset";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Asset</h3>
                    <small class="opacity-75">Modify the details of your digital asset</small>
                </div>
                <input type="hidden" asp-for="Url" />
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Url" />
                        <input type="hidden" asp-for="OwnerId" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-tag"></i></span>
                                <input asp-for="Name" class="form-control border-start-0" placeholder="e.g. Low Poly Sword" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Tell us about your asset..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input asp-for="Price" class="form-control border-start-0" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-4 border rounded-4 shadow-sm" style="background-color: #f1f3f5; border: 1px solid #dee2e6 !important;">
                            <label class="form-label fw-bold d-block text-dark mb-2">
                                <i class="bi bi-cloud-upload me-2 text-primary"></i>Update Model File
                            </label>

                            <div class="p-2 mb-3 rounded-3 bg-white border border-opacity-10 small">
                                <span class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Current File:</span>
                                <div class="text-primary text-truncate font-monospace" style="font-size: 0.8rem;">
                                    @Model.Url
                                </div>
                            </div>

                            <input type="file" name="file" class="form-control border-0 shadow-sm mb-2" style="background-color: #ffffff;" />

                            <div class="d-flex align-items-center mt-2">
                                <div class="badge bg-dark-subtle text-dark fw-normal rounded-pill px-3 py-2" style="font-size: 0.75rem;">
                                    <i class="bi bi-info-circle me-1"></i> Keep empty to retain current version
                                </div>
                            </div>
                        </div>
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="mb-4 p-4 border rounded-4 shadow-sm" style="background-color: #f8f9fa; border: 1px solid #dee2e6 !important;">
                            <label class="form-label fw-bold d-block text-dark mb-2">
                                <i class="bi bi-image me-2 text-success"></i>Update Thumbnail Image
                            </label>

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-3">
                                    <span class="text-muted small fw-bold text-uppercase">Current Thumbnail:</span>
                                    <div class="mt-1">
                                        <img src="@Model.ImageUrl" alt="Current Thumbnail" class="rounded-3 shadow-sm" style="height: 80px; width: 120px; object-fit: cover; border: 1px solid #ddd;">
                                    </div>
                                </div>
                            }

                            <input type="file" name="imageFile" accept="image/*" class="form-control border-0 shadow-sm mb-2" style="background-color: #ffffff;" />

                            <div class="d-flex align-items-center mt-2">
                                <div class="badge bg-success-subtle text-success fw-normal rounded-pill px-3 py-2" style="font-size: 0.75rem;">
                                    <i class="bi bi-info-circle me-1"></i> Leave empty to keep current image
                                </div>
                            </div>
                        </div>
                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="bi bi-save me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Back to Assets
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}