@model IEnumerable<GameAssetStore.Models.Asset>
@using System.Security.Claims
@{
    ViewData["Title"] = "Asset Store";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold text-dark mb-1">Explore Assets</h1>
            <p class="text-muted">Discover high-quality 3D models for your next project.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Publish Asset
        </a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden asset-card">

                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 220px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-dark d-flex align-items-center justify-content-center" style="height: 220px;">
                                <i class="bi bi-box-seam display-4 text-white-50"></i>
                            </div>
                        }
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-dark bg-opacity-75 backdrop-blur px-3 py-2 rounded-pill fs-6">
                                $@item.Price
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold text-truncate mb-1">@item.Name</h5>
                        <p class="card-text text-muted small mb-3 text-truncate-2" style="height: 40px;">
                            @(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                        </p>

                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark w-100 rounded-3">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                            <a asp-action="Buy" asp-route-id="@item.Id" class="btn btn-primary w-100 rounded-3 shadow-sm">
                                <i class="bi bi-cart-plus me-1"></i>Buy
                            </a>
                        </div>
                    </div>

                   

                @if (User.Identity.IsAuthenticated && item.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                    {
                        <div class="card-footer bg-transparent border-0 pb-3 text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-link btn-sm text-decoration-none text-muted">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-link btn-sm text-decoration-none text-danger">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Premium efekti za kartice */
    .asset-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border: 1px solid rgba(0,0,0,.05) !important;
    }

        .asset-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    /* Ograničavanje opisa na 2 linije */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Blur efekt za cijenu */
    .backdrop-blur {
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    .btn-primary {
        background-color: #0d6efd;
        border: none;
    }

    body {
        background-color: #f8f9fa;
    }
</style>