@model GameAssetStore.Models.Asset
@using System.Security.Claims

@{
    ViewData["Title"] = "Asset Details";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Store</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid w-100" alt="@Model.Name" style="max-height: 500px; object-fit: cover;">
                }
                else
                {
                    <div class="bg-dark d-flex align-items-center justify-content-center" style="height: 400px;">
                        <i class="bi bi-box-seam display-1 text-white-50"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h2 class="fw-bold mb-0">@Model.Name</h2>
                    <span class="badge bg-success fs-4 rounded-pill px-3 py-2">
                        $@Model.Price
                    </span>
                </div>

                <p class="text-secondary mb-4" style="white-space: pre-line;">
                    @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this asset." : Model.Description)
                </p>

                <div class="d-grid gap-2 mb-4">
                    <a asp-action="Buy" asp-route-id="@Model.Id" class="btn btn-primary btn-lg rounded-3 py-3 shadow">
                        <i class="bi bi-cart-plus me-2"></i>Purchase Now
                    </a>
                </div>

                <div class="p-4 rounded-4 mb-4" style="background-color: #212529; border-left: 5px solid #0d6efd;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-file-earmark-zip fs-2 text-white me-3"></i>
                        <div>
                            <h6 class="mb-0 fw-bold text-white small text-uppercase">Secure Package</h6>
                            <p class="mb-0 text-white-50 small">Original files on GitHub Cloud</p>
                        </div>
                    </div>
                </div>

                @if (User.Identity.IsAuthenticated && Model.OwnerId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                {
                    <div class="border-top pt-4 mt-auto">
                        <h6 class="fw-bold text-muted small text-uppercase mb-3">Seller Controls</h6>
                        <div class="d-grid gap-2 d-md-flex">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm flex-grow-1">
                                <i class="bi bi-pencil-square me-2"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm flex-grow-1">
                                <i class="bi bi-trash me-2"></i>Delete
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="mt-5">
        <a asp-action="Index" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i>Back to Store Catalog
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}