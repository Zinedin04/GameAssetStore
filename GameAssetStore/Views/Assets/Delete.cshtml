@model GameAssetStore.Models.Asset

@{
    ViewData["Title"] = "Delete Asset";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white p-4 rounded-top-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill display-4 mb-2"></i>
                    <h3 class="mb-0">Delete Asset?</h3>
                    <p class="mb-0 opacity-75">This action cannot be undone.</p>
                </div>

                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4 text-center border-0 shadow-sm" role="alert">
                        Are you sure you want to permanently remove <strong>@Model.Name</strong>?
                    </div>

                    <div class="list-group list-group-flush border rounded-4 overflow-hidden mb-4 shadow-sm">
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3 bg-light">
                            <span class="text-muted fw-bold small text-uppercase">Asset Name</span>
                            <span class="fw-bold">@Model.Name</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <span class="text-muted fw-bold small text-uppercase">Price</span>
                            <span class="badge bg-success rounded-pill fs-6">$@Model.Price</span>
                        </div>
                        <div class="list-group-item p-3 bg-light">
                            <span class="text-muted fw-bold small text-uppercase d-block mb-1">Description</span>
                            <p class="mb-0 text-secondary small">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                        </div>
                        <div class="list-group-item p-3 bg-dark text-white-50">
                            <span class="text-white fw-bold small text-uppercase d-block mb-1 opacity-75 font-monospace" style="font-size: 0.7rem;">GitHub Cloud Path</span>
                            <code class="text-info small text-truncate d-block">@Model.Url</code>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3 me-md-2">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-5 py-2 rounded-3 shadow">
                                <i class="bi bi-trash3 me-2"></i>Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4 px-3">
                <p class="small text-muted mb-0">
                    <i class="bi bi-info-circle me-1"></i> This will remove the record from our database and attempt to delete the file from your GitHub repository.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}